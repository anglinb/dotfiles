#!/usr/bin/env bash

# Check for Homebrew
if command -v brew >/dev/null 2>&1; then
    echo "✅ Homebrew is already installed at: $(which brew)"
else
    echo "🚀 Homebrew not found. Installing Homebrew..."

    # Detect OS
    OS=$(uname -s)

    if [ "$OS" = "Darwin" ]; then
        echo "🔍 Detected macOS. Installing using official script..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    elif [ "$OS" = "Linux" ]; then
        echo "🔍 Detected Linux. Installing using official script..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    else
        echo "❌ Unsupported OS: $OS. Exiting."
        exit 1
    fi

    # Add Homebrew to PATH for current session
    if [ -d "/home/linuxbrew/.linuxbrew/bin" ]; then
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    elif [ -d "/opt/homebrew/bin" ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi

    echo "✅ Homebrew installation complete!"
    echo "👉 You may want to add the following to your shell profile:"
    echo '    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"  # for Linux'
    echo '    eval "$(/opt/homebrew/bin/brew shellenv)"              # for macOS Apple Silicon'
fi

# Check for ~/.dotfiles
if [ -d "$HOME/.dotfiles" ]; then
    echo "✅ ~/.dotfiles already exists."
else
    echo "📁 ~/.dotfiles not found. Cloning from GitHub..."
    git clone https://github.com/anglinb/dotfiles.git "$HOME/.dotfiles" || {
        echo "❌ Failed to clone dotfiles repo."
        exit 1
    }
    echo "✅ Successfully cloned dotfiles to ~/.dotfiles"
fi
